# ============================================================
# REQUIRED: AI API Key (bắt buộc để AI features hoạt động)
# ============================================================
# Hỗ trợ 2 providers:
#   - OpenRouter (prefix "sk-or-..."): gọi qua OpenRouter API
#   - Google Gemini (prefix "AIza..."): gọi trực tiếp Gemini API
# Đăng ký: https://openrouter.ai/keys  hoặc  https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# ============================================================
# OPTIONAL: AI Model Name (chỉ dùng cho OpenRouter)
# ============================================================
# Mặc định: google/gemma-4-31b:free (nếu để trống)
# Các model phổ biến:
#   - google/gemma-4-31b:free
#   - openai/gpt-4o-mini
#   - anthropic/claude-3-haiku
#   - google/gemini-2.0-flash
# Xem danh sách: https://openrouter.ai/models
AI_MODEL=google/gemma-4-31b:free
